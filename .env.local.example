# ===================================================
# คัดลอกไฟล์นี้เป็น .env.local แล้วกรอกค่าที่ถูกต้อง
# Copy this file to .env.local and fill in the values
# ===================================================

# Database (MySQL)
DATABASE_URL=mysql://root:password@localhost:3306/door_access_system

# OAuth (จาก Manus Platform)
VITE_APP_ID=your_app_id_here
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im

# JWT Secret (สุ่มได้เอง เช่น: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_key_here

# Owner OpenID (OpenID ของแอดมินหลัก — ดูได้จาก login ครั้งแรก)
OWNER_OPEN_ID=

# Backend URL (สำหรับ ESP32)
BACKEND_URL=http://localhost:3000

# Webhook URLs (Optional)
LINE_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email / SMTP (Optional — สำหรับ Email Notification)
# ตัวอย่าง Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com, SMTP_PASS=<App Password>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# AWS S3 (Optional — ข้ามได้ถ้าไม่ใช้)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=ap-southeast-1
